doctype html
html
	head
		title= title

		style.
			table {
				border-collapse: collapse;
				width: 100%;
				margin-top: 20px;
			}

			th, td {
				border: 1px solid #ccc;
				padding: 10px;
				text-align: left;
			}

			th {
				background: #f5f5f5;
			}

	body
		h1 Uploaded Files

		if files.length === 0
			p No uploaded files
		else
			table
				thead
					tr
						th fileName
						th originalName
						th size
						th uploadedAt

				tbody
					each file in files
						tr
							td= file.fileName
							td= file.originalName
							td= file.size
							td= file.uploadedAt